# GlamGo — Local Environment Variables
# ----------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → anon (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → service_role (secret)
# ⚠️  KEEP THIS SECRET — never expose client-side. Used only for seed scripts and admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Interswitch (for payment integration)
# Found in: Interswitch Developer Dashboard → Your App → Keys
INTERSWITCH_CLIENT_ID=
INTERSWITCH_CLIENT_SECRET=
INTERSWITCH_PRODUCT_ID=
INTERSWITCH_PAY_ITEM_ID=
